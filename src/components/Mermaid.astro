---
const { chart } = Astro.props;
---

<div class="mermaid">
  {chart}
</div>

<script client:load>
  import("https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs")
    .then((mermaid) => {
      mermaid.default.initialize({
        startOnLoad: true,
        theme: "neutral",
        securityLevel: "loose"
      });

      mermaid.default.run();
    });
</script>